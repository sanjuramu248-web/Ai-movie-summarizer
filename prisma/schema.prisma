// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Movie {
  id          String   @id @default(uuid())
  imdbId      String   @unique
  title       String
  poster      String?
  year        String?
  rating      String?
  plot        String?
  cast        String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  reviews     Review[]
  aiInsight   AIInsight?
}

model Review {
  id        String   @id @default(uuid())
  movieId   String
  author    String?
  content   String
  rating    Float?
  createdAt DateTime @default(now())

  movie Movie @relation(fields: [movieId], references: [id], onDelete: Cascade)
}

model AIInsight {
  id          String   @id @default(uuid())
  movieId     String   @unique
  summary     String
  sentiment   Sentiment
  createdAt   DateTime @default(now())

  movie Movie @relation(fields: [movieId], references: [id], onDelete: Cascade)
}


enum Sentiment {
  POSITIVE
  MIXED
  NEGATIVE
}